ANTHROPIC_API_KEY=sk-ant-...
# OPTIONAL — social signal is deferred out of the MVP (decision log 2026-07-02).
# Leave unset: the Reddit cycle is dormant and self-activates if credentials appear.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=streetwise/1.0 by u/yourusername
# Metra developer bearer token (register at metra.com/metra-gtfs-api). Used only by the
# realtime feeds at gtfspublic.metrarr.com (alerts/positions/tripupdates); the static
# schedule zip that builds the gazetteer is public and needs no key.
METRA_GTFS_API_KEY=
