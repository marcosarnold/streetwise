ANTHROPIC_API_KEY=sk-ant-...
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=streetwise/1.0 by u/yourusername
# Metra GTFS is credential-gated — free keys at metra.com/developers. Until set,
# scripts/build_gazetteer.py builds CTA-only and Metra alerts fall back to Nominatim.
METRA_GTFS_ACCESS_KEY=...
METRA_GTFS_SECRET_KEY=...
